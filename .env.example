# Copy to .env and fill values.

# Wallet that OWNS the Functions subscription (and is allowlisted).
PRIVATE_KEY=0x...

# RPC endpoint for the chain where Functions DON lives (e.g. Sepolia).
WEB3_RPC_URL=https://sepolia.infura.io/v3/<KEY>

# Chainlink Functions router (the on-chain router contract address for the network).
CHAINLINK_ROUTER_ADDRESS=0xb83E47C2bC239B3bf370bc41e1459A34b41238D0

# DON id (text form).
CHAINLINK_DON_ID_TEXT=fun-ethereum-sepolia-1

# Gateways (comma-separated).
CHAINLINK_GATEWAY_URLS=https://01.functions-gateway.testnet.chain.link/,https://02.functions-gateway.testnet.chain.link/

# CRE simulator / onchain registry key.
# Raw 64-character hex, no 0x prefix.
CRE_ETH_PRIVATE_KEY=...

# Optional RPCs used by CRE workflows/config targets.
ETHEREUM_SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/<KEY>
ETHEREUM_MAINNET_RPC_URL=https://mainnet.infura.io/v3/<KEY>

